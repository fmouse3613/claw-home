{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and OpenClaw chat windows",
  "windows": ["main", "openclaw-chat*"],
  "remote": {
    "urls": [
      "http://127.0.0.1:18789/*",
      "http://localhost:18789/*"
    ]
  },
  "permissions": [
    "core:default",
    "opener:default"
  ]
}
